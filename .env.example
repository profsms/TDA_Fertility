# ============================================================
#  .env.example
#  Copy this file to .env and fill in your credentials.
#  .env is git-ignored and must never be committed.
#
#  Register for a free HFD account at:
#    https://www.humanfertility.org
#  The same credentials work for both HFD_* and HMD_*.
# ============================================================

HFD_EMAIL=your_email@example.com
HFD_PASSWORD=your_password_here

HMD_EMAIL=your_email@example.com
HMD_PASSWORD=your_password_here
